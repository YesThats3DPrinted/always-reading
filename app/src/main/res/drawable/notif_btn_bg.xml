<?xml version="1.0" encoding="utf-8"?>
<!-- Subtle rounded-rectangle background for tappable elements in the
     notification expanded view (arrows and title).
     Semi-transparent grey works in both light and dark mode. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#22808080" />
    <corners android:radius="8dp" />
</shape>
