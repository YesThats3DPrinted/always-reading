<?xml version="1.0" encoding="utf-8"?>
<!--
    Small status-bar icon for the persistent notification.
    Android renders small icons as white silhouettes using the alpha channel only,
    so all color values here are irrelevant — only the filled shape matters.
    The infinity path is a filled version so it reads clearly at tiny sizes.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Filled infinity symbol — stroked version is too thin at status-bar size -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
            M9.5,8.5
            C7.0,8.5 5.0,10.0 5.0,12.0
            C5.0,14.0 7.0,15.5 9.5,15.5
            C11.2,15.5 12.7,14.6 13.5,13.4
            C14.3,14.6 15.8,15.5 17.5,15.5
            C20.0,15.5 22.0,14.0 22.0,12.0
            C22.0,10.0 20.0,8.5 17.5,8.5
            C15.8,8.5 14.3,9.4 13.5,10.6
            C12.7,9.4 11.2,8.5 9.5,8.5 Z
            M9.5,10.0
            C11.1,10.0 12.2,10.9 12.7,12.0
            C12.2,13.1 11.1,14.0 9.5,14.0
            C7.8,14.0 6.5,13.1 6.5,12.0
            C6.5,10.9 7.8,10.0 9.5,10.0 Z
            M17.5,10.0
            C19.2,10.0 20.5,10.9 20.5,12.0
            C20.5,13.1 19.2,14.0 17.5,14.0
            C15.9,14.0 14.8,13.1 14.3,12.0
            C14.8,10.9 15.9,10.0 17.5,10.0 Z" />

    <!-- Left temple nub: tiny capsule overlapping slightly inside left loop -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M4.7,11.7 L4.9,11.7 A0.3,0.3 0 0 1 4.9,12.3 L4.7,12.3 A0.3,0.3 0 0 1 4.7,11.7 Z" />

    <!-- Right temple nub: tiny capsule overlapping slightly inside right loop -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M22.1,11.7 L22.3,11.7 A0.3,0.3 0 0 1 22.3,12.3 L22.1,12.3 A0.3,0.3 0 0 1 22.1,11.7 Z" />

</vector>
