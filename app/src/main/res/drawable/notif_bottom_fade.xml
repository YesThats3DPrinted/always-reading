<?xml version="1.0" encoding="utf-8"?>
<!-- Gradient overlay applied to the bottom of the collapsed notification sentence area.
     Fades from transparent (top) to solid purple (bottom) to signal "swipe down to expand". -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="270"
        android:startColor="#006650A4"
        android:endColor="#FF6650A4" />
</shape>
