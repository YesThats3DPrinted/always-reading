<?xml version="1.0" encoding="utf-8"?>
<!-- Pill background + ripple for the title bar in the notification.
     Ripple color #33FFFFFF matches Material3 IconButton on dark backgrounds.
     Inset shrinks the visible pill to ~70% of the row height
     without reducing the tappable area.
     12dp corners matches Material3 card radius. -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#33FFFFFF">

    <!-- Normal state: inset semi-transparent pill -->
    <item>
        <inset
            android:insetTop="6dp"
            android:insetBottom="6dp">
            <shape android:shape="rectangle">
                <solid android:color="#22808080" />
                <corners android:radius="12dp" />
            </shape>
        </inset>
    </item>

    <!-- Mask: required for RemoteViews touch dispatch AND ripple clipping -->
    <item android:id="@android:id/mask">
        <inset
            android:insetTop="6dp"
            android:insetBottom="6dp">
            <shape android:shape="rectangle">
                <solid android:color="#FFFFFFFF" />
                <corners android:radius="12dp" />
            </shape>
        </inset>
    </item>

</ripple>
