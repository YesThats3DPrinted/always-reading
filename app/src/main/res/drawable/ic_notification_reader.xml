<?xml version="1.0" encoding="utf-8"?>
<!--
    Notification toggle icon: ‹ [___] ›
    Left chevron, outlined rounded rectangle, right chevron.
    No outer card — the three elements stand alone.
    Tinted by Compose: primary colour (purple) when notification is on, grey when off.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Left chevron ‹ -->
    <path
        android:pathData="M5,9.5 L2.5,12 L5,14.5"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"/>

    <!-- Centre outlined rectangle [___] -->
    <path
        android:pathData="M9.7,9 L14.3,9 A1.2,1.2 0 0,1 15.5,10.2 L15.5,13.8 A1.2,1.2 0 0,1 14.3,15 L9.7,15 A1.2,1.2 0 0,1 8.5,13.8 L8.5,10.2 A1.2,1.2 0 0,1 9.7,9 Z"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.5"/>

    <!-- Right chevron › -->
    <path
        android:pathData="M19,9.5 L21.5,12 L19,14.5"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"/>

</vector>
