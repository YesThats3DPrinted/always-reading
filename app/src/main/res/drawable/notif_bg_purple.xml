<?xml version="1.0" encoding="utf-8"?>
<!-- Rounded-corner purple shape that matches MIUI's ~14 dp card radius so the
     inner content view fills the grey container edge-to-edge. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#6650A4" />
    <corners android:radius="14dp" />
</shape>
