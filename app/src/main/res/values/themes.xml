<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. Compose handles all the theming; this is just
         the window/activity theme needed before Compose takes over. -->
    <style name="Theme.AlwaysReading" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
