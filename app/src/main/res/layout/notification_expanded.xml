<?xml version="1.0" encoding="utf-8"?>
<!-- Expanded notification view.
     Row 1: [← weight=1] [title weight=4] [→ weight=1]
     Row 2: ScrollView (140dp fixed height) wrapping tv_sentence — scrollable for any font size,
             no maxLines so text is never truncated.
     Tapping the title or sentence text opens the app (explicit setOnClickPendingIntent only —
     no setContentIntent on the builder, so the arrows never accidentally open the app).
     Background set at runtime via setInt("setBackgroundColor"). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/notif_root_expanded"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="8dp"
    android:paddingTop="2dp"
    android:paddingBottom="10dp">

    <!-- Title row with arrows on either side -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_prev"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="←"
            android:textColor="#AAFFFFFF"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tv_notification_title"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="4"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:textColor="#FFFFFFFF"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_next"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="→"
            android:textColor="#AAFFFFFF"
            android:textSize="18sp" />

    </LinearLayout>

    <!-- Sentence text. Android's RemoteViews whitelist does NOT include ScrollView,
         so we cap at 8 lines and rely on the 250-char segment limit to prevent
         most overflow. ellipsize is a last-resort safety net. -->
    <TextView
        android:id="@+id/tv_sentence"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="6dp"
        android:ellipsize="end"
        android:lineSpacingMultiplier="1.3"
        android:maxLines="8"
        android:textColor="#FFFFFFFF"
        android:textSize="15sp" />

</LinearLayout>
