<?xml version="1.0" encoding="utf-8"?>
<!-- Expanded notification view.
     Row 1: [← ImageButton weight=1] [title TextView weight=4] [→ ImageButton weight=1]
     Row 2: sentence text (maxLines=8)
     Text/icon colors set at runtime based on dark/light mode. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/notif_root_expanded"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="8dp"
    android:paddingTop="6dp"
    android:paddingBottom="10dp">

    <!-- Title row with arrow buttons on either side -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btn_prev"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/notif_btn_bg"
            android:scaleType="center"
            android:src="@drawable/ic_arrow_left" />

        <TextView
            android:id="@+id/tv_notification_title"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="4"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/notif_btn_bg"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:paddingHorizontal="10dp"
            android:textSize="11sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btn_next"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/notif_btn_bg"
            android:scaleType="center"
            android:src="@drawable/ic_arrow_right" />

    </LinearLayout>

    <!-- Sentence text. RemoteViews whitelist does NOT include ScrollView,
         so we cap at 8 lines. ellipsize is a last-resort safety net. -->
    <TextView
        android:id="@+id/tv_sentence"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="6dp"
        android:ellipsize="end"
        android:lineSpacingMultiplier="1.3"
        android:maxLines="8"
        android:textSize="15sp" />

</LinearLayout>
