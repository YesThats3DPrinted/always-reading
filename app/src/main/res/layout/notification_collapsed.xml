<?xml version="1.0" encoding="utf-8"?>
<!-- Collapsed (small) notification.
     The sentence text is clipped at a fixed FrameLayout height with a gradient fade
     at the bottom — this signals to the user that there is more text and the
     notification can be expanded by swiping down.
     Background set at runtime via setInt("setBackgroundColor"). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/notif_root_collapsed"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="8dp"
    android:paddingTop="2dp"
    android:paddingBottom="8dp">

    <!-- Title row: [← weight=1] [Book · Chapter · % weight=4] [→ weight=1] -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_prev"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="←"
            android:textColor="#AAFFFFFF"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tv_notification_title"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="4"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:textColor="#FFFFFFFF"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_next"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="→"
            android:textColor="#AAFFFFFF"
            android:textSize="18sp" />

    </LinearLayout>

    <!-- Sentence preview clipped to 64dp.
         A 32dp gradient overlay at the bottom fades the text to purple,
         clearly indicating the notification can be expanded. -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="6dp"
        android:layout_marginHorizontal="6dp"
        android:clipChildren="true">

        <TextView
            android:id="@+id/tv_sentence"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingMultiplier="1.3"
            android:textColor="#FFFFFFFF"
            android:textSize="15sp" />

        <!-- Gradient fade — transparent at top, solid purple at bottom.
             Declared after tv_sentence so it renders on top of the text. -->
        <TextView
            android:id="@+id/fade_overlay"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:layout_gravity="bottom"
            android:background="@drawable/notif_bottom_fade" />

    </FrameLayout>

</LinearLayout>
